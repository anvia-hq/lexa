{
  "name": "lexa-index",
  "version": "0.10.0",
  "description": "Fast code intelligence for AI agents, powered by the precompiled Lexa Rust binary",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lexa": "bin/lexa.js"
  },
  "files": [
    "bin/lexa.js",
    "index.js",
    "skill.js",
    "lib/",
    "skill/SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./index.js",
    "./skill": "./skill.js"
  },
  "optionalDependencies": {
    "lexa-index-darwin-arm64": "0.10.0",
    "lexa-index-darwin-x64": "0.10.0",
    "lexa-index-linux-x64": "0.10.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anvia-hq/lexa.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
