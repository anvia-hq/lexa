---
type Props = {
  label: string
  command: string
}

const { label, command } = Astro.props
---

<div class="border-l border-stone-800 py-1 pl-4">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="m-0 p-0 text-xs leading-[1.4] text-stone-500">{label}</p>
      <pre class="m-0 mt-1 overflow-x-auto p-0"><code class="font-mono text-sm leading-[1.5] text-stone-200">{command}</code></pre>
    </div>
    <button
      class="shrink-0 border border-stone-800 px-2 py-1 text-xs leading-none text-stone-500 transition hover:border-stone-600 hover:text-stone-200"
      type="button"
      data-copy-button
      data-copy-value={command}
    >
      Copy
    </button>
  </div>
</div>

<script>
  async function writeClipboard(value: string) {
    if (navigator.clipboard?.writeText && window.isSecureContext) {
      await navigator.clipboard.writeText(value)
      return
    }

    const textarea = document.createElement('textarea')
    textarea.value = value
    textarea.setAttribute('readonly', '')
    textarea.style.position = 'fixed'
    textarea.style.opacity = '0'
    document.body.appendChild(textarea)
    textarea.select()
    document.execCommand('copy')
    textarea.remove()
  }

  document.addEventListener('click', async (event) => {
    const target = event.target
    if (!(target instanceof Element)) return

    const button = target.closest('[data-copy-button]')
    if (!(button instanceof HTMLButtonElement)) return

    const value = button.dataset.copyValue
    if (!value) return

    const previousText = button.textContent ?? 'Copy'
    try {
      await writeClipboard(value)
      button.textContent = 'Copied'
    } catch {
      button.textContent = 'Failed'
    }

    window.setTimeout(() => {
      button.textContent = previousText
    }, 1200)
  })
</script>
